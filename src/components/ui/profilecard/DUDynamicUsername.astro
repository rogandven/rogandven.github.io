---
import type SocialLink from '../../../classes/SocialLink.ts';
import { DEFAULT_ICON_TEXTSIZE, DEFAULT_ICON_ICONSIZE, DAISYUI_LINK_COLORS } from '../../../constants/daisyui.constants';

interface Props {
    links: SocialLink[],
    textSize?: string,
    iconSize?: string,
}

const { 
    links = [],
    textSize = DEFAULT_ICON_TEXTSIZE,
    iconSize = DEFAULT_ICON_ICONSIZE,
} = Astro.props;
---
<span class={`text-rotate duration-6000 ${textSize}`}>
  <span>
    {
        links.map((link, index) => {
            const LOGO_CLASS = `${textSize} ${iconSize}`;
            const Logo = link.icon;
            return <span>
                <a 
                    class={`link ${DAISYUI_LINK_COLORS[index % DAISYUI_LINK_COLORS.length]}`}
                    href={link.URL} 
                    target="_blank"
                    aria-label={link.displayName}
                >
                    <div class="flex flex-row align-middle items-center-safe justify-items-center-safe">
                        <Logo class={LOGO_CLASS} _class={LOGO_CLASS}/>
                        <span class="ml-1">
                                {link.username}
                        </span>
                    </div>
                </a>
            </span>;
        })
    }
  </span>
</span>